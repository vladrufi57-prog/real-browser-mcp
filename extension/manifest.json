{
  "manifest_version": 3,
  "name": "Real Browser MCP Bridge",
  "description": "Auto-connects your real Chromium browser to a local MCP relay without per-tab manual connect.",
  "version": "0.1.0",
  "permissions": [
    "debugger",
    "tabs",
    "storage",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "ws://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Real Browser MCP Bridge"
  }
}
